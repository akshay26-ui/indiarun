# Database — paste your Supabase or Neon connection string here
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Sync URL used by Alembic migrations (swap asyncpg → psycopg2)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Frontend origin for CORS
FRONTEND_URL=http://localhost:3000
